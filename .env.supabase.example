# Supabase PostgreSQL
# Anda a tu proyecto en supabase.com > Settings > Database > Connection string
# Usa el formato "Transaction pooler" (puerto 6543) para serverless como Render

DB_URL=jdbc:postgresql://aws-0-us-west-1.pooler.supabase.com:6543/postgres
DB_USERNAME=postgres.tuproyecto
DB_PASSWORD=tu-password-de-supabase

# JWT - genera uno seguro: openssl rand -base64 64
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-de-64-caracteres-minimo

# URLs
FRONTEND_URL=https://tu-app-en-render.onrender.com

# JPA
DDL_AUTO=update
SHOW_SQL=false

# Tiempo del token JWT (24 horas)
JWT_EXPIRATION_MS=86400000

# MercadoPago (opcional al inicio, podes usar mock)
MP_ACCESS_TOKEN=APP_USR-7786118604850582-052909-9952021c912f8837e93b470308723e87-3435704948
MP_WEBHOOK_SECRET=webhook-secret-cambiar-en-produccion
