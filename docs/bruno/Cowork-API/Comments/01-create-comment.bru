meta {
  name: Create Comment
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/products/{{productId}}/comments
  body: json
}

headers {
  Content-Type: application/json
  Accept: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "rating": 5,
    "content": "Excelente cafe, muy buen aroma y trazabilidad."
  }
}
